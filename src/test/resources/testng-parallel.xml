<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="Parallel Devices" parallel="tests" thread-count="2" verbose="1" preserve-order="true">

    <!-- Register unified media + Allure listener -->
    <listeners>
        <listener class-name="listeners.AllureTestListener"/>
    </listeners>

    <test name="PHONE">
        <parameter name="udid" value="emulator-5554"/>
        <parameter name="serverPort" value="0"/>
        <parameter name="systemPort" value="0"/>
        <parameter name="chromedriverPort" value="0"/>
        <parameter name="noReset" value="true"/>
        <classes>
            <class name="tests.Test1"/>
            <class name="tests.Test2"/>
            <class name="tests.Test3"/>
            <class name="tests.Test4"/>
        </classes>
    </test>

    <test name="PIXEL_XL">
        <parameter name="udid" value="emulator-5556"/>
        <parameter name="serverPort" value="0"/>
        <parameter name="systemPort" value="0"/>
        <parameter name="chromedriverPort" value="0"/>
        <parameter name="noReset" value="true"/>
        <classes>
            <class name="tests.Test1"/>
            <class name="tests.Test2"/>
            <class name="tests.Test3"/>
            <class name="tests.Test4"/>
            <class name="tests.Test5"/>
        </classes>
    </test>

</suite>
